{
  "services": {
    "agent-schedule-service": {
      "source_paths": [
        "rust/cloud-storage/scheduled_action/**"
      ],
      "stack_path": "infra/stacks/agent-schedule-service/**",
      "deploy_binaries": [
        "service"
      ]
    },
    "authentication-service": {
      "source_paths": [
        "rust/cloud-storage/authentication_service/**",
        "rust/cloud-storage/referral/**",
        "rust/cloud-storage/teams/**",
        "rust/cloud-storage/user_link_cleanup_handler/**"
      ],
      "stack_path": "infra/stacks/authentication-service/**",
      "deploy_binaries": [
        "authentication_service"
      ],
      "deploy_lambdas": [
        "user_link_cleanup_handler"
      ]
    },
    "bulk-upload": {
      "source_paths": [
        "rust/cloud-storage/upload_extractor_lambda_handler/**",
        "rust/cloud-storage/upload_extractor_lambda_trigger/**"
      ],
      "stack_path": "infra/stacks/bulk-upload/**",
      "deploy_lambdas": [
        "upload_extractor_lambda_handler",
        "upload_extractor_lambda_trigger"
      ]
    },
    "connection-gateway": {
      "source_paths": [
        "rust/cloud-storage/connection_gateway/**"
