# [DEV] Deploy the agent to LiveKit Cloud
deploy-dev:
    cp livekit.dev.toml livekit.toml
    lk agent deploy

# [PROD] Deploy the agent to LiveKit Cloud
deploy-prod:
    cp livekit.prod.toml livekit.toml
    lk agent deploy

# Run the agent locally in console mode
dev:
    python transcriber.py console

# Stream agent logs from LiveKit Cloud
logs:
    lk agent logs

# Check agent deployment status
status:
    lk agent status

# Install Python dependencies
install:
    pip install -r requirements.txt
