# iOS: dev-facing, for testing in Simulator
ios-dev: ios-prepare-tauri-api
    cd tauri/src-tauri && cargo tauri ios dev --open -- --no-default-features

# iOS: prod-facing build, with bundle auto-update turned off, for testing locally on actual iPhone
ios-build-no-update: ios-prepare-tauri-api
    cd tauri/src-tauri && cargo tauri ios build --open -- --no-default-features

# iOS: build for release
ios-build: ios-prepare-tauri-api
    cd tauri/src-tauri && cargo tauri ios build --open

# Xcode resolves SwiftPM packages before Tauri's Rust build script can generate
# local plugin Swift dependencies, so prepare the ignored Tauri iOS API first.
ios-prepare-tauri-api:
    bun scripts/prepare-tauri-ios-api.mjs

# Tauri build hook (run automatically via beforeDevCommand) — not meant to be run directly
[private]
dev-tauri:
    printf development > tauri/src-tauri/.macro-tauri-env
    cd packages/app && bun run --bun dev

# List available local service names
local-services:
    @sed -n "s/.*'\([a-z][-a-z]*\)':.*/\1/p" packages/core/constant/servers.ts | sort -u

# Run the app with local services (defaults to ALL)
# This assumes you have followed the RUNNING_LOCALLLY.md instructions
servers := 'ALL'
port := '3000'

local:
    cd packages/app && PORT='{{port}}' VITE_LOCAL_SERVERS='{{servers}}' bun run --bun dev

local-sync-playground:
    cd packages/app && VITE_LOCAL_SERVERS='ALL' VITE_SYNC_SERVICE_HOST='sync-service-playground.macroverse.workers.dev' bun run --bun dev

local-dcs:
    cd packages/app && VITE_LOCAL_SERVERS='cognition-service,cognition-websocket-service' bun run --bun dev

local-dss:
    cd packages/app && VITE_LOCAL_SERVERS='document-storage-service' bun run --bun dev

local-search:
    cd packages/app && VITE_LOCAL_SERVERS='search-service' bun run --bun dev

local-email:
    cd packages/app && VITE_LOCAL_SERVERS='email-service' bun run --bun dev

build-dev:
    cd packages/app && MODE=development NODE_ENV=production bun run --bun build

build-staging:
    cd packages/app && MODE=staging NODE_ENV=production bun run --bun build

build-prod:
    cd packages/app && MODE=production NODE_ENV=production bun run --bun build

# Tauri build hook (run automatically via beforeBuildCommand) — not meant to be run directly
[private]
build-tauri:
    printf production > tauri/src-tauri/.macro-tauri-env
    cd packages/app && MODE=production NODE_ENV=production bun run --bun build

# Build the bundle, zip it, and install it at
# rust/cloud-storage/tools/native_app_server/app-archive.zip for the bundle
# updater test server. The server hashes the archive at request time, so no
# checksum wiring is needed.
dist-archive: build-prod
    #!/usr/bin/env bash
    set -euo pipefail
    TARGET="$(cd {{ justfile_directory() }}/../../rust/cloud-storage/tools/native_app_server && pwd)/app-archive.zip"
    rm -f "$TARGET"
    (cd packages/app/dist && zip -qr "$TARGET" .)
    echo "Archive: $TARGET"

bundle-smoke-server *ARGS:
    # Local manual OTA smoke server. Example:
    # just bundle-smoke-server older --host 0.0.0.0 --port 3001
    bun scripts/smoke-bundle-updater-server.ts {{ARGS}}

test-watch:
    bunx --bun vitest

test-email-rendering:
    cd packages/core/email/tests && bunx playwright test && bunx playwright show-report

test-email-rendering-update:
    cd packages/core/email/tests && bunx playwright test --update-snapshots

preview-prod:
    cd packages/app && MODE=production NODE_ENV=production bun run preview:prod

lint-staged:
    bunx --bun biome lint --staged

lint-ci:
    bunx --bun biome ci --changed

storybook:
    cd packages/ui && bun run storybook

build-storybook:
    cd packages/ui && bun run build-storybook

java-build:
    bun scripts/createBackend.js

csharp-build:
    bun scripts/publish-docx-server.js

# Codegen
gen-api *SERVICES:
    bun scripts/generate-api-schema.ts {{SERVICES}}

gen-dcs-types:
    bun scripts/generate-dcs-types.ts

gen-dcs-types-local:
    MODE=local bun scripts/generate-dcs-types.ts

gen-dcs-tools:
    bun scripts/generate-dcs-tools.ts

gen-dcs-models:
    bun scripts/generate-dcs-models.ts

clean-env:
    bun scripts/clean-env.js

pkg:
    bun scripts/pkg.ts

check-tailwind:
    bun scripts/check-tailwind.ts

fix-lock:
    git fetch origin dev:dev && git checkout dev -- bun.lock && bun i && git add bun.lock

# Analysis
cycles:
    bunx --bun biome lint --only=nursery/noImportCycles

cycles-ci:
    bunx --bun biome lint --changed --only=nursery/noImportCycles
