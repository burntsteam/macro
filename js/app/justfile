dev-tauri:
    cd packages/app && bun run --bun dev:tauri

# List available local service names
local-services:
    @sed -n "s/.*'\([a-z][-a-z]*\)':.*/\1/p" packages/core/constant/servers.ts | sort -u

# Run the app with local services (defaults to ALL)
# This assumes you have followed the RUNNING_LOCALLLY.md instructions
servers := 'ALL'
port := '3000'

local:
    cd packages/app && PORT='{{port}}' VITE_LOCAL_SERVERS='{{servers}}' bun run --bun dev

local-dcs:
    cd packages/app && VITE_LOCAL_SERVERS='cognition-service,cognition-websocket-service' bun run --bun dev

local-dss:
    cd packages/app && VITE_LOCAL_SERVERS='document-storage-service' bun run --bun dev

local-search:
    cd packages/app && VITE_LOCAL_SERVERS='search-service' bun run --bun dev

local-email:
    cd packages/app && VITE_LOCAL_SERVERS='email-service' bun run --bun dev

build-dev:
    cd packages/app && MODE=development NODE_ENV=production bun run --bun build

build-staging:
    cd packages/app && MODE=staging NODE_ENV=production bun run --bun build

build-prod:
    cd packages/app && MODE=production NODE_ENV=production bun run --bun build

build-tauri:
    cd packages/app && MODE=production NODE_ENV=production bun run --bun build:tauri

test-watch:
    bunx --bun vitest

test-email-rendering:
    cd packages/core/email/tests && bunx playwright test && bunx playwright show-report

test-email-rendering-update:
    cd packages/core/email/tests && bunx playwright test --update-snapshots

preview-prod:
    cd packages/app && MODE=production NODE_ENV=production bun run preview:prod

lint-staged:
    bunx --bun biome lint --staged

lint-ci:
    bunx --bun biome ci --changed

storybook:
    cd packages/ui && bun run storybook

build-storybook:
    cd packages/ui && bun run build-storybook

java-build:
    bun scripts/createBackend.js

csharp-build:
    bun scripts/publish-docx-server.js

# Codegen
gen-api *SERVICES:
    bun scripts/generate-api-schema.ts {{SERVICES}}

gen-dcs-types:
    bun scripts/generate-dcs-types.ts

gen-dcs-types-local:
    MODE=local bun scripts/generate-dcs-types.ts

gen-dcs-tools:
    bun scripts/generate-dcs-tools.ts

gen-dcs-models:
    bun scripts/generate-dcs-models.ts

clean-env:
    bun scripts/clean-env.js

pkg:
    bun scripts/pkg.ts

check-tailwind:
    bun scripts/check-tailwind.ts

fix-lock:
    git fetch origin dev:dev && git checkout dev -- bun.lock && bun i && git add bun.lock

# Analysis
cycles:
    bunx --bun biome lint --only=nursery/noImportCycles

cycles-ci:
    bunx --bun biome lint --changed --only=nursery/noImportCycles
