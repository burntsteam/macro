  "query": "\n            SELECT user_id, \n                team_role as \"team_role!: TeamRole\",\n                tier as \"tier!: TeamUserTier\"\n            FROM team_user\n            WHERE team_id = $1 AND team_role NOT IN ('owner')\n            ",
