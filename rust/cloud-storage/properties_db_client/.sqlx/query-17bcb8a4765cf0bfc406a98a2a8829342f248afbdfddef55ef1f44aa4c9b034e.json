{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT \n            ep.entity_id,\n            ep.entity_type as \"entity_type: EntityType\"\n        FROM entity_properties ep\n        JOIN property_definitions pd ON ep.property_definition_id = pd.id\n        WHERE ep.id = $1\n          AND pd.is_system = FALSE\n        ",
