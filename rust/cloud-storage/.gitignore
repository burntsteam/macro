ai_tools/schemas/

# But keep the lambda directory
!/target/lambda/

# And all files under lambda subdirectories
!/target/lambda/**/bootstrap
!/target/lambda/**/bootstrap.zip

!*/**/.env.sample
*/**/.env

# Root .env file for docker-compose
/.env

