  "db_name": "PostgreSQL",
  "query": "\n            SELECT id, owner, name, schedule, kind, timezone, task, claimed, created_at, updated_at, next_run_at, enabled\n            FROM scheduled_action\n            WHERE enabled\n              AND (claimed IS NULL OR claimed < $1)\n            ORDER BY next_run_at ASC\n            LIMIT $2\n            ",
