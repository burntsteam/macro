FROM debian:trixie-slim AS runner
ARG SERVICE_NAME=__MISSING_SERVICE_NAME__
WORKDIR /app

RUN apt-get update \
  && apt-get install -y --no-install-recommends \
    ca-certificates \
    dumb-init \
  && apt-get clean \
  && rm -rf /var/lib/apt/lists/*

# Copy the runtime closure and pre-built Linux binary from the GitHub Actions artifact.
COPY ./prebuilt/nix-store/ /nix/store/
COPY --chmod=755 ./prebuilt/${SERVICE_NAME} /app/svc

ENV PORT=8080
EXPOSE ${PORT}
ENTRYPOINT ["dumb-init", "./svc"]
