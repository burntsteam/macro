import './database.just'

mod sqlx './sqlx.just'

check:
    RUSTFLAGS=-Dwarnings RUSTDOCFLAGS=-Dwarnings CARGO_TERM_COLOR=always SQLX_OFFLINE=true cargo check

clippy:
    RUSTFLAGS="-Dwarnings -Dclippy::disallowed_methods" RUSTDOCFLAGS=-Dwarnings CARGO_TERM_COLOR=always SQLX_OFFLINE=true cargo clippy --workspace --all-features

# This can be used in any crate that uses macrodb under the hood
[no-cd]
prepare_db:
    just sqlx::prepare_db {{ DATABASE_URL }}

format:
    SQLX_OFFLINE=true cargo fmt

clean:
    cargo clean
    git restore target/lambda

build:
    SQLX_OFFLINE=true cargo build

# Build dev service Docker images to pre-warm the cache used by root `run_local`.
build_dev_service_images:
  docker build -f Dockerfile.dev --target services_bundle -t macro-local-rust-services:dev .
  docker build -f Dockerfile.search_processing_service.dev --target search_processing_service -t macro-local-search-processing-service:dev .

# Build all lambda functions
build_lambdas compiler="":
    ulimit -n 10240 && just docx_unzip_handler/build {{compiler}}
    ulimit -n 10240 && just call_recording_preview_handler/build {{compiler}}
    ulimit -n 10240 && just delete_chat_handler/build {{compiler}}
    ulimit -n 10240 && just organization_retention_handler/build {{compiler}}
    ulimit -n 10240 && just organization_retention_trigger/build {{compiler}}
    ulimit -n 10240 && just upload_extractor_lambda_trigger/build {{compiler}}
    ulimit -n 10240 && just upload_extractor_lambda_handler/build {{compiler}}
    ulimit -n 10240 && just worker_trigger/build {{compiler}}
    ulimit -n 10240 && just dataloss_prevention_handler/build {{compiler}}
    ulimit -n 10240 && just search_upload_handler/build {{compiler}}
    ulimit -n 10240 && just document_text_extractor/build {{compiler}}
    ulimit -n 10240 && just document_upload_finalizer_handler/build {{compiler}}
    ulimit -n 10240 && just email_suppression_handler/build {{compiler}}
    ulimit -n 10240 && just deleted_item_poller/build {{compiler}}
    ulimit -n 10240 && just email_refresh_handler/build {{compiler}}
    ulimit -n 10240 && just user_link_cleanup_handler/build {{compiler}}
    ulimit -n 10240 && just email_scheduled_handler/build {{compiler}}
