  "query": "\n        SELECT\n            cr.id AS \"call_id!\",\n            cr.channel_id AS \"channel_id!\",\n            cr.created_by AS \"created_by!\",\n            cc.name AS \"channel_name?\"\n        FROM call_records cr\n        LEFT JOIN comms_channels cc ON cc.id = cr.channel_id\n        WHERE cr.id = $1\n        ",
