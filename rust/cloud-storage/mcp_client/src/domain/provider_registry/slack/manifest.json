{
	"display_information": {
		"name": "Macro",
		"description": "Macro's MCP integration for Slack",
		"background_color": "#000000",
		"long_description": "The Macro : Slack MCP integration will allow users to effortlessly use slack communication in the macro workspace. The macro workspace provides a chat client that can act on user requests to do things within the Macro platform and to act on behalf of the user in connected apps."
	},
	"oauth_config": {
		"redirect_urls": [
			"https://document-cognition.macro.com/mcp/servers/auth/callback",
			"https://document-cognition-dev.macro.com/mcp/servers/auth/callback"
		],
		"scopes": {
			"user": [
				"canvases:read",
				"channels:history",
				"channels:read",
				"chat:write",
				"files:read",
				"groups:history",
				"groups:read",
				"groups:write",
				"im:history",
				"im:write",
				"reactions:write",
				"search:read.files",
				"search:read.im",
				"search:read.mpim",
				"search:read.private",
				"search:read.public",
				"search:read.users",
				"users:read",
				"users:read.email"
			]
		},
		"pkce_enabled": false
	},
	"settings": {
		"org_deploy_enabled": true,
		"socket_mode_enabled": false,
		"token_rotation_enabled": false,
		"is_mcp_enabled": true
	}
}
