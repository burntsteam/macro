{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT\n                bt.id AS token_id,\n                bt.bot_id,\n                bt.token,\n                bt.label,\n                bt.last_used_at,\n                bt.expires_at,\n                bt.revoked_at,\n                bt.created_at,\n                b.kind\n            FROM bot_tokens bt\n            JOIN bots b ON b.id = bt.bot_id\n            WHERE bt.token = $1\n              AND b.deleted_at IS NULL\n            ",
