  "query": "\n        SELECT\n            c.hidden AS \"hidden!\",\n            c.team_id AS \"team_id!\",\n            tu.team_role AS \"role!: TeamRole\"\n        FROM crm_companies c\n        JOIN team_user tu\n            ON tu.team_id = c.team_id\n           AND tu.user_id = $1\n        WHERE c.id = $2\n        ",
