  "db_name": "PostgreSQL",
  "query": "\n            SELECT\n                id,\n                thread_id AS \"thread_id!\",\n                sender_id,\n                content,\n                created_at,\n                updated_at,\n                edited_at::timestamptz AS \"edited_at?\"\n            FROM comms_messages\n            WHERE thread_id = $1\n              AND deleted_at IS NULL\n            ORDER BY created_at ASC, id ASC\n            ",
