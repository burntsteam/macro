  "query": "\n            SELECT\n                id,\n                company_id,\n                email,\n                name,\n                hidden,\n                first_interaction,\n                last_interaction,\n                created_at,\n                updated_at\n            FROM crm_contacts\n            WHERE company_id = $1\n              AND ($2 OR hidden = FALSE)\n            ORDER BY LOWER(COALESCE(name, email)) ASC, id DESC\n            ",
