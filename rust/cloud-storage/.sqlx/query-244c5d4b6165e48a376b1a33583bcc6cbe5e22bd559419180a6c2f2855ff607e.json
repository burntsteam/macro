{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT\n                id,\n                channel_id,\n                thread_id,\n                sender_id,\n                content,\n                created_at,\n                updated_at,\n                edited_at::timestamptz AS \"edited_at?\",\n                deleted_at::timestamptz AS \"deleted_at?\"\n            FROM comms_messages\n            WHERE channel_id = $1\n              AND (created_at, id) > ($2, $3)\n            ORDER BY created_at ASC, id ASC\n            LIMIT $4\n            ",
