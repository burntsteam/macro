{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT c.id, c.team_id, c.email_sync, c.hidden, c.created_at, c.updated_at\n            FROM crm_companies c\n            JOIN crm_domains d ON d.company_id = c.id\n            WHERE c.team_id = $1\n              AND LOWER(d.domain) = $2\n            LIMIT 1\n            ",
