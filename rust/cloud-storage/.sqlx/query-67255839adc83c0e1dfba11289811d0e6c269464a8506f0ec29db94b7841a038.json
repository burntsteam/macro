{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT\n                b.id,\n                b.kind,\n                b.owner_user_id,\n                b.team_id,\n                b.name,\n                b.handle,\n                b.description,\n                b.avatar_url,\n                b.created_by,\n                b.created_at,\n                b.updated_at,\n                b.deleted_at\n            FROM bots b\n            JOIN comms_channel_participants cp\n              ON cp.user_id = ('bot|' || b.id::text)\n            WHERE cp.channel_id = $1\n              AND cp.left_at IS NULL\n              AND b.deleted_at IS NULL\n            ORDER BY b.created_at ASC, b.id ASC\n            ",
