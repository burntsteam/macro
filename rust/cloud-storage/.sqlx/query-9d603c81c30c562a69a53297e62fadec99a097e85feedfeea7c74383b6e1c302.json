{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT o.id, o.team_id, o.name, o.email_sync, o.created_at\n            FROM crm_organization o\n            JOIN crm_organization_domain d ON d.crm_organization_id = o.id\n            WHERE o.team_id = $1\n              AND LOWER(d.domain) = $2\n            LIMIT 1\n            ",
