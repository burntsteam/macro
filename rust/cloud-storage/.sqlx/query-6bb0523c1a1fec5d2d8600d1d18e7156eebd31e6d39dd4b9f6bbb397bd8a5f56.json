  "query": "\n            SELECT\n                user_id,\n                channel_id,\n                joined_at,\n                left_at::timestamptz AS \"left_at?\",\n                role AS \"role: ParticipantRole\"\n            FROM comms_channel_participants\n            WHERE channel_id = $1 AND left_at IS NULL\n            ORDER BY joined_at DESC\n            ",
