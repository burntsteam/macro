{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT\n            (ct.hidden OR c.hidden) AS \"hidden!\",\n            c.team_id AS \"team_id!\",\n            tu.team_role AS \"role!: TeamRole\"\n        FROM crm_contacts ct\n        JOIN crm_companies c\n            ON c.id = ct.company_id\n        JOIN team_user tu\n            ON tu.team_id = c.team_id\n           AND tu.user_id = $1\n        WHERE ct.id = $2\n        ",
