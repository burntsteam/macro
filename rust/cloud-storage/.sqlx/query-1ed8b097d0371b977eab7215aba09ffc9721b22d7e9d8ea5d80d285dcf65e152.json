  "query": "\n          SELECT\n              ca.id,\n              ca.\"chatId\" as \"chat_id\",\n              ca.\"entity_id\"::TEXT as \"attachment_id!\",\n              ca.\"entity_type\" as \"attachment_type: AttachmentType\",\n              ca.\"messageId\" as \"message_id\"\n          FROM\n              \"ChatAttachment\" ca\n          WHERE ca.\"chatId\" = $1\n          ORDER BY ca.id ASC\n    ",
