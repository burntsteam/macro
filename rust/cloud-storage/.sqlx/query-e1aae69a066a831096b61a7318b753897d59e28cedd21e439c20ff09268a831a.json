{
  "db_name": "PostgreSQL",
  "query": "\n            UPDATE bots\n            SET name = COALESCE($2, name),\n                handle = COALESCE($3, handle),\n                description = COALESCE($4, description),\n                avatar_url = COALESCE($5, avatar_url),\n                updated_at = now()\n            WHERE id = $1\n              AND deleted_at IS NULL\n            RETURNING\n                id,\n                kind,\n                owner_user_id,\n                team_id,\n                name,\n                handle,\n                description,\n                avatar_url,\n                created_by,\n                created_at,\n                updated_at,\n                deleted_at\n            ",
