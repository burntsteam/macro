  "query": "\n            SELECT\n                channel_id,\n                user_id,\n                role AS \"role: ParticipantRole\",\n                joined_at,\n                left_at::timestamptz AS \"left_at?\"\n            FROM comms_channel_participants\n            WHERE channel_id = $1 AND left_at IS NULL\n            ORDER BY joined_at ASC\n            ",
