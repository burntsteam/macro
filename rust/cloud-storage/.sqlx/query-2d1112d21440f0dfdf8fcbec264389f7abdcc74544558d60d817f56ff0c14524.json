  "query": "\n        SELECT\n            d.id as \"document_id\",\n            d.owner,\n            d.name as \"document_name\",\n            d.\"fileType\" as \"file_type\",\n            dst.sub_type as \"sub_type?: DocumentSubType\"\n        FROM\n            \"Document\" d\n        LEFT JOIN document_sub_type dst ON dst.document_id = d.id\n        WHERE d.id = ANY($1)\n        ",
