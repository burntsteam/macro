{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT\n                m.id as message_id,\n                c.id,\n                c.link_id,\n                c.email_address,\n                COALESCE(m.from_name, c.name) as \"name\",\n                c.original_photo_url,\n                c.sfs_photo_url,\n                c.created_at,\n                c.updated_at\n            FROM email_messages m\n            INNER JOIN email_contacts c ON c.id = m.from_contact_id\n            WHERE m.id = ANY($1)\n            AND m.from_contact_id IS NOT NULL\n        ",
