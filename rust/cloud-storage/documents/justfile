# Apply markdown lifecycle backfill against prod DB/sync-service.
# Extra script flags can be passed directly after the recipe name, for example:
# just backfill_markdown_content_location_prod_apply --limit 100 --batch-size 25
backfill_markdown_content_location_prod_apply *FLAGS:
    #!/usr/bin/env bash
    set -euo pipefail
    echo -e "\033[31mWARNING: this will update PRODUCTION Document.contentState/contentLocation for markdown documents found in sync-service.\033[0m"
    echo -e "\033[31mThis may also initialize missing PRODUCTION sync-service documents if --initialize-missing is passed.\033[0m"
    echo -n "Type 'prod backfill' to continue: "
    read -r response
    if [[ "$response" != "prod backfill" ]]; then
        echo "Production backfill cancelled."
        exit 0
    fi
    DATABASE_URL="$(../scripts/rds_database_url.sh macro-db-prod macrodb-password-prod macrodb)"
    SYNC_SERVICE_AUTH_KEY="$(aws secretsmanager get-secret-value --secret-id sync-service-key-prod --query SecretString --output text)"
    INTERNAL_API_SECRET_KEY="$(aws secretsmanager get-secret-value --secret-id document-storage-service-auth-key-prod --query SecretString --output text)"
    eval "$(aws configure export-credentials --format env)"
    DOCUMENT_STORAGE_BUCKET="macro-document-storage-prod"
    RUST_LOG="${RUST_LOG:-info}" ENVIRONMENT="prod" DATABASE_URL="$DATABASE_URL" SYNC_SERVICE_AUTH_KEY="$SYNC_SERVICE_AUTH_KEY" INTERNAL_API_SECRET_KEY="$INTERNAL_API_SECRET_KEY" DOCUMENT_STORAGE_BUCKET="$DOCUMENT_STORAGE_BUCKET" \
        cargo run -p documents --features backfill_binary --bin backfill_markdown_content_location -- --apply {{ FLAGS }}
