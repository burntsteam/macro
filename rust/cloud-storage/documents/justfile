import '../database.just'

mod sqlx '../sqlx.just'

prepare_db:
    just sqlx::prepare_db {{ DATABASE_URL }}

check:
  cargo check --all-features

# Dry-run markdown lifecycle backfill against dev DB/sync-service.
# Extra script flags can be passed directly after the recipe name, for example:
# just backfill_markdown_content_location_dev --limit 100 --batch-size 25
backfill_markdown_content_location_dev *FLAGS:
    #!/usr/bin/env bash
    set -euo pipefail
    DATABASE_URL="$(../scripts/rds_database_url.sh macro-db-dev macrodb-password-dev macrodb)"
    SYNC_SERVICE_AUTH_KEY="$(aws secretsmanager get-secret-value --secret-id sync-service-key-dev --query SecretString --output text)"
    INTERNAL_API_SECRET_KEY="$(aws secretsmanager get-secret-value --secret-id document-storage-service-auth-key-dev --query SecretString --output text)"
    eval "$(aws configure export-credentials --format env)"
    DOCUMENT_STORAGE_BUCKET="doc-storage-dev"
    RUST_LOG="${RUST_LOG:-info}" ENVIRONMENT="dev" DATABASE_URL="$DATABASE_URL" SYNC_SERVICE_AUTH_KEY="$SYNC_SERVICE_AUTH_KEY" INTERNAL_API_SECRET_KEY="$INTERNAL_API_SECRET_KEY" DOCUMENT_STORAGE_BUCKET="$DOCUMENT_STORAGE_BUCKET" \
        cargo run -p documents --features backfill_binary --bin backfill_markdown_content_location -- {{ FLAGS }}

# Apply markdown lifecycle backfill against dev DB/sync-service.
# Extra script flags can be passed directly after the recipe name, for example:
# just backfill_markdown_content_location_dev_apply --limit 100 --batch-size 25
backfill_markdown_content_location_dev_apply *FLAGS:
    #!/usr/bin/env bash
    set -euo pipefail
    echo -e "\033[33mWARNING: this will update dev Document.contentState/contentLocation for markdown documents found in sync-service.\033[0m"
    echo -n "Continue? [y/N] "
    read -r response
    if [[ ! "$response" =~ ^[Yy]$ ]]; then
        echo "Backfill cancelled."
        exit 0
    fi
    DATABASE_URL="$(../scripts/rds_database_url.sh macro-db-dev macrodb-password-dev macrodb)"
    SYNC_SERVICE_AUTH_KEY="$(aws secretsmanager get-secret-value --secret-id sync-service-key-dev --query SecretString --output text)"
    INTERNAL_API_SECRET_KEY="$(aws secretsmanager get-secret-value --secret-id document-storage-service-auth-key-dev --query SecretString --output text)"
    eval "$(aws configure export-credentials --format env)"
    DOCUMENT_STORAGE_BUCKET="doc-storage-dev"
    RUST_LOG="${RUST_LOG:-info}" ENVIRONMENT="dev" DATABASE_URL="$DATABASE_URL" SYNC_SERVICE_AUTH_KEY="$SYNC_SERVICE_AUTH_KEY" INTERNAL_API_SECRET_KEY="$INTERNAL_API_SECRET_KEY" DOCUMENT_STORAGE_BUCKET="$DOCUMENT_STORAGE_BUCKET" \
        cargo run -p documents --features backfill_binary --bin backfill_markdown_content_location -- --apply {{ FLAGS }}

