{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT\n            m.id,\n            m.provider_id,\n            m.global_id,\n            m.thread_id,\n            m.provider_thread_id,\n            m.replying_to_id,\n            m.link_id,\n            m.provider_history_id,\n            m.internal_date_ts,\n            m.snippet,\n            m.size_estimate,\n            m.subject,\n            m.from_name,\n            m.from_contact_id,\n            m.sent_at,\n            m.has_attachments,\n            m.is_read,\n            m.is_starred,\n            m.is_sent,\n            m.is_draft,\n            m.body_text,\n            m.body_html_sanitized,\n            m.body_macro,\n            m.headers_jsonb,\n            m.created_at,\n            m.updated_at\n        FROM email_messages m\n        JOIN email_scheduled_messages sm ON m.id = sm.message_id\n        WHERE m.link_id = $1 AND sm.sent = false\n        ORDER BY m.created_at DESC\n        LIMIT $2 OFFSET $3\n        ",
