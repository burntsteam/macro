# syntax=docker/dockerfile:1
FROM rust:latest AS chef
ENV SQLX_OFFLINE=true
WORKDIR /app

FROM chef AS builder
COPY . .

# Build ALL standard service binaries at once (with BuildKit cache mounts for incremental builds)
RUN --mount=type=cache,target=/usr/local/cargo/registry,sharing=shared \
    --mount=type=cache,target=/usr/local/cargo/git/db,sharing=shared \
    --mount=type=cache,target=/app/target,id=rust-target-dev-debug,sharing=locked \
    cargo build \
        --bin authentication_service \
        --bin connection_gateway_service \
        --bin contacts_service \
        --bin document_cognition_service \
        --bin document_storage_service \
        --bin email_service \
        --bin notification_service \
        --bin static_file_service \
        --bin unfurl_service \
    && mkdir -p /app/out \
    && cp /app/target/debug/authentication_service /app/out/ \
    && cp /app/target/debug/connection_gateway_service /app/out/ \
    && cp /app/target/debug/contacts_service /app/out/ \
    && cp /app/target/debug/document_cognition_service /app/out/ \
    && cp /app/target/debug/document_storage_service /app/out/ \
    && cp /app/target/debug/email_service /app/out/ \
    && cp /app/target/debug/notification_service /app/out/ \
    && cp /app/target/debug/static_file_service /app/out/ \
    && cp /app/target/debug/unfurl_service /app/out/

# Base runtime image
FROM debian:trixie-slim AS base
RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates openssl dumb-init curl \
    && apt-get clean && rm -rf /var/lib/apt/lists/*
WORKDIR /app
ENV PORT=8080
EXPOSE 8080

# Individual service targets
FROM base AS authentication_service
COPY --from=builder /app/out/authentication_service /app/svc
RUN chmod +x /app/svc
ENTRYPOINT ["dumb-init", "./svc"]

FROM base AS connection_gateway_service
COPY --from=builder /app/out/connection_gateway_service /app/svc
RUN chmod +x /app/svc
ENTRYPOINT ["dumb-init", "./svc"]

FROM base AS contacts_service
COPY --from=builder /app/out/contacts_service /app/svc
RUN chmod +x /app/svc
ENTRYPOINT ["dumb-init", "./svc"]

FROM base AS document_cognition_service
COPY --from=builder /app/out/document_cognition_service /app/svc
RUN chmod +x /app/svc
ENTRYPOINT ["dumb-init", "./svc"]

FROM base AS document_storage_service
COPY --from=builder /app/out/document_storage_service /app/svc
RUN chmod +x /app/svc
ENTRYPOINT ["dumb-init", "./svc"]

FROM base AS email_service
COPY --from=builder /app/out/email_service /app/svc
RUN chmod +x /app/svc
ENTRYPOINT ["dumb-init", "./svc"]

FROM base AS notification_service
COPY --from=builder /app/out/notification_service /app/svc
RUN chmod +x /app/svc
ENTRYPOINT ["dumb-init", "./svc"]

FROM base AS static_file_service
COPY --from=builder /app/out/static_file_service /app/svc
RUN chmod +x /app/svc
ENTRYPOINT ["dumb-init", "./svc"]

FROM base AS unfurl_service
COPY --from=builder /app/out/unfurl_service /app/svc
RUN chmod +x /app/svc
ENTRYPOINT ["dumb-init", "./svc"]
