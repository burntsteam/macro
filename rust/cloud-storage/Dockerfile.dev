FROM rust:latest AS chef
ENV SQLX_OFFLINE=true
WORKDIR /app

FROM chef AS builder
COPY . .

# Build ALL standard service binaries at once
RUN cargo build \
    --bin authentication_service \
    --bin connection_gateway_service \
    --bin contacts_service \
    --bin document_cognition_service \
    --bin document_storage_service \
    --bin email_service \
    --bin notification_service \
    --bin static_file_service \
    --bin unfurl_service

# Base runtime image
FROM debian:trixie-slim AS base
RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates openssl dumb-init curl \
    && apt-get clean && rm -rf /var/lib/apt/lists/*
WORKDIR /app
ENV PORT=8080
EXPOSE 8080

# Individual service targets
FROM base AS authentication_service
COPY --from=builder /app/target/debug/authentication_service /app/svc
RUN chmod +x /app/svc
ENTRYPOINT ["dumb-init", "./svc"]

FROM base AS connection_gateway_service
COPY --from=builder /app/target/debug/connection_gateway_service /app/svc
RUN chmod +x /app/svc
ENTRYPOINT ["dumb-init", "./svc"]

FROM base AS contacts_service
COPY --from=builder /app/target/debug/contacts_service /app/svc
RUN chmod +x /app/svc
ENTRYPOINT ["dumb-init", "./svc"]

FROM base AS document_cognition_service
COPY --from=builder /app/target/debug/document_cognition_service /app/svc
RUN chmod +x /app/svc
ENTRYPOINT ["dumb-init", "./svc"]

FROM base AS document_storage_service
COPY --from=builder /app/target/debug/document_storage_service /app/svc
RUN chmod +x /app/svc
ENTRYPOINT ["dumb-init", "./svc"]

FROM base AS email_service
COPY --from=builder /app/target/debug/email_service /app/svc
RUN chmod +x /app/svc
ENTRYPOINT ["dumb-init", "./svc"]

FROM base AS notification_service
COPY --from=builder /app/target/debug/notification_service /app/svc
RUN chmod +x /app/svc
ENTRYPOINT ["dumb-init", "./svc"]

FROM base AS static_file_service
COPY --from=builder /app/target/debug/static_file_service /app/svc
RUN chmod +x /app/svc
ENTRYPOINT ["dumb-init", "./svc"]

FROM base AS unfurl_service
COPY --from=builder /app/target/debug/unfurl_service /app/svc
RUN chmod +x /app/svc
ENTRYPOINT ["dumb-init", "./svc"]
