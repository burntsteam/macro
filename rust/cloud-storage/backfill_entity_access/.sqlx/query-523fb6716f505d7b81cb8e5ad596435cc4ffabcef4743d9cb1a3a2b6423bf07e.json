  "db_name": "PostgreSQL",
  "query": "\n            SELECT DISTINCT\n                \"item_id\",\n                \"item_type\",\n                \"user_id\",\n                access_level AS \"access_level: AccessLevel\",\n                \"created_at\"\n            FROM \"UserItemAccess\"\n            WHERE \"granted_from_channel_id\" IS NULL\n            AND \"granted_from_team_id\" IS NULL\n            ORDER BY created_at ASC\n            LIMIT $1\n            OFFSET $2\n            ",
